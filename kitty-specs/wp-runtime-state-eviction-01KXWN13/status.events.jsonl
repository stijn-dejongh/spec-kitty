{"aggregate_id": "01KXWN13GH4QCRMS28N448V7CR", "aggregate_type": "Mission", "event_id": "01KXWN13NN0FJSEFAQVKSGR352", "event_type": "MissionCreated", "payload": {"created_at": "2026-07-19T07:39:10.225993+00:00", "friendly_name": "Evict WP runtime state into the event log", "mission_id": "01KXWN13GH4QCRMS28N448V7CR", "mission_number": null, "mission_slug": "wp-runtime-state-eviction-01KXWN13", "mission_type": "software-dev", "purpose_context": "The WP markdown file today holds both static design intent and runtime-mutable state written on every lifecycle event. That split churns the dossier content hash, forces operators to hand-tick subtask checkboxes before review, and splits status truth between markdown and the event log. This mission (the #2684 P0, implementing the #2093 authority ruling) evicts all runtime-mutable state into a single generic InnerStateChanged event folded into the reduced snapshot, leaving WP files as static design intent.", "purpose_tldr": "Single-source work-package runtime state in the append-only event log instead of the WP markdown files, ending the status split-brain and the content-hash churn.", "target_branch": "mission-prep/2684-wp-runtime-state-eviction", "wp_count": 0}, "project_slug": "spec-kitty", "project_uuid": "8a4a7da6-a97c-4bb4-893a-b31664abfee4", "schema_version": "5.0.0", "timestamp": "2026-07-19T07:39:10.389052+00:00"}

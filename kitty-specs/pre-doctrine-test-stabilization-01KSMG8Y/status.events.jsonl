{"aggregate_id": "01KSMG8Y0V5V2ZM4YEQMKFWN2K", "aggregate_type": "Mission", "event_id": "01KSMG8YNDF7J0DCQ8ZWHB9CNT", "event_type": "MissionCreated", "payload": {"created_at": "2026-05-27T10:39:21.115628+00:00", "friendly_name": "Pre-Doctrine Test Stabilization", "mission_id": "01KSMG8Y0V5V2ZM4YEQMKFWN2K", "mission_number": null, "mission_slug": "pre-doctrine-test-stabilization-01KSMG8Y", "mission_type": "software-dev", "purpose_context": "The 01KSF9HJ triage mission identified and filed 10 DIR-013 sub-issues covering confirmed pre-existing failures across charter, doctrine, status, sync, next-CLI, and architectural-guard surfaces. None of those fixes landed in upstream/main. This mission resolves all 10 clusters in four ordered waves (quick fixes \u2192 structural fixes \u2192 shared-package fixes \u2192 re-baseline closeout), adds a mandatory test-mark audit to ensure every new and existing test in touched directories is correctly tagged for the CI-quality workflow's fast/integration/e2e split, and declares the test suite stable enough for follow-on doctrine and charter work to proceed.", "purpose_tldr": "Fix the 10 confirmed pre-existing test failure clusters (#1301\u2013#1310) and enforce CI test-mark hygiene so the repo has a \u226475-failure baseline before doctrine/charter feature work resumes.", "target_branch": "feat/pre-doctrine-stabilization-remediation", "wp_count": 0}, "project_slug": "spec-kitty", "project_uuid": "8a4a7da6-a97c-4bb4-893a-b31664abfee4", "schema_version": "5.0.0", "timestamp": "2026-05-27T10:39:21.773571+00:00"}
